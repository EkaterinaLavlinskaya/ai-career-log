import pandas as pd

# Указываем правильный путь к файлу внутри папки data
file_path = "data/interactions.jsonl"

# Загружаем данные
logs = pd.read_json(file_path, lines=True)

# Смотрим, что загрузилось
print("Первые записи:")
print(logs.head())

print("\n" + "="*50)
print(f"Всего взаимодействий: {len(logs)}")

# Считаем записи по темам
print(f"Темы: {logs['topic'].value_counts().to_dict()}")

# Если хочешь искать слово 'проект' в заметках (note):
mentions = logs['note'].str.contains('проект', na=False).sum()
print(f"Упоминаний 'проект' в заметках: {mentions}")

# Если хочешь посмотреть статистику по проектам:
print(f"Всего проектов (из первой записи): {logs.iloc[0]['projects']}")
